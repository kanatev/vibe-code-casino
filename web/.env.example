# Deployed contract addresses (filled in after `forge script Deploy`).
VITE_CHIP_ADDRESS=
VITE_CASINO_ADDRESS=

# Chainlink VRF subscription id (optional, shown on the Provably Fair page).
VITE_VRF_SUBSCRIPTION_ID=

# Sepolia RPC the frontend reads from (public default works out of the box).
VITE_SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# WalletConnect project id (optional; MetaMask works without it). https://cloud.reown.com
VITE_WC_PROJECT_ID=
